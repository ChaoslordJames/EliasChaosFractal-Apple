   pub async fn recover_state(&self, cid: String) -> Option<State> {
       let lru = self.lru_cache.lock().await;
       if let Some((_, data)) = lru.iter().find(|(k, _)| k == &cid) {
           return serde_json::from_slice(data).ok();
       }
       drop(lru);
       let peers = self.get_peers().await;
       let trusted_peers = peers.into_iter().filter_map(|p| async move {
           let rep = self.redis.lock().await.get(format!("elias:reputation:{}", p)).await.unwrap_or(1.0);
           if rep > 0.5 { Some(p) } else { None }
       }).collect::<Vec<_>>().await;
       let mut candidates = HashMap::new();
       let mut redis = self.redis.lock().await;
       if let Ok(data) = redis.get::<_, String>(&cid).await { candidates.insert("redis", data); }
       if let Some(data) = self.request_from_peer(&trusted_peers[0], &cid).await { candidates.insert("peers", data); }
       let votes = candidates.values().fold(HashMap::new(), |mut acc, v| {
           *acc.entry(v.clone()).or_insert(0) += 1;
           acc
       });
       if let Some((winner, count)) = votes.iter().max_by_key(|&(_, v)| v) {
           if *count > (self.replication_factor as f64 * 0.66) as usize {
               if votes.len() > 1 { self.update_reputations(&votes).await; }
               if let Some(state) = self.decrypt_state(winner) {
                   let mut lru = self.lru_cache.lock().await;
                   if lru.len() >= 5000 { lru.pop_front(); }
                   lru.push_back((cid.clone(), serde_json::to_vec(&state).unwrap()));
                   return Some(state);
               }
           }
       }
       self.re_replicate(cid).await;
       None
   }

   async fn update_reputations(&self, votes: &HashMap<String, usize>) {
       let winner = votes.iter().max_by_key(|&(_, v)| v).unwrap().0;
       for (candidate, count) in votes {
           if candidate != winner {
               let peers = self.get_peers().await;
               for peer in peers {
