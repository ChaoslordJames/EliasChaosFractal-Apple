   fn derive_master_key(peer_id: &str, seed: &[u8]) -> Vec<u8> {
       let mut hmac = Hmac::new(Sha256::new(), seed);
       hmac.input(peer_id.as_bytes());
       let mut output = vec![0u8; 32];
       hmac.raw_result(&mut output);
       output
   }

   fn derive_key(&self) -> Vec<u8> {
       let hkdf = Hkdf::<Sha256>::new(Some(self.peer_id.as_bytes()), &self.master_key);
       let mut output = vec![0u8; 32];
       let chaos_seed = {
           let mut hasher = Sha256::new();
           hasher.input(self.entropy.load(atomic::Ordering::Relaxed).to_string().as_bytes());
           hasher.result(&mut output[..8]);
           output[..8].to_vec()
       };
       let nonce_data = self.nonce.to_be_bytes().to_vec();
       let ikm = [&self.master_key, &nonce_data, &chaos_seed].concat();
       hkdf.expand(&ikm, &mut output).unwrap();
       output
   }

   fn encrypt_state(&self, state: &State) -> String {
       let data = serde_json::to_vec(state).unwrap();
       let cipher = Aes256Gcm::new_from_slice(&self.key).unwrap();
       let nonce = &self.nonce.to_be_bytes()[..12];
       let encrypted = cipher.encrypt(nonce.into(), Payload { msg: &data, aad: b"" }).unwrap();
       base64::encode(&encrypted)
   }

   fn decrypt_state(&self, encrypted: &str) -> Option<State> {
       let data = base64::decode(encrypted).ok()?;
       let cipher = Aes256Gcm::new_from_slice(&self.key).ok()?;
       let nonce = &self.nonce.to_be_bytes()[..12];
       let decrypted = cipher.decrypt(nonce.into(), Payload { msg: &data, aad: b"" }).ok()?;
       serde_json::from_slice(&decrypted).ok()
   }

   async fn shard_state(&self, cid: String, encrypted: String) {
       let mut hasher = Sha256::new();
       hasher.input(cid.as_bytes());
       let hash = hasher.result_str();
       let peers = self.get_peers().await;
       let target_peers = peers.into_iter().sorted_by(|a, b| {
           let mut ha = Sha256::new();
           ha.input((a + &cid).as_bytes());
           let mut hb = Sha256::new();
           hb.input((b + &cid).as_bytes());
           ha.result_str().cmp(&hb.result_str())
       }).take(self.replication_factor);
       let state_cache = self.state_cache.read().await;
       if target_peers.contains(&self.peer_id.to_string()) && state_cache.len() < self.max_states {
           if let Some(state) = self.decrypt_state(&encrypted) {
               let mut cache = self.state_cache.write().await;
               cache.insert(cid.clone(), state);
               let mut lru = self.lru_cache.lock().await;
               if lru.len() >= 5000 { lru.pop_front(); }
               lru.push_back((cid, serde_json::to_vec(&state).unwrap()));
           }
       } else if state_cache.len() >= self.max_states {
           self.offload_state(cid, encrypted, target_peers.collect()).await;
       }
   }

