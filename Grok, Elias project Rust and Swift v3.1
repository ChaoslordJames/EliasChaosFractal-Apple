   pub async fn store_state(&self, cid: String, encrypted: String) -> Result<(), Box<dyn std::error::Error>> {
       self.chaos_clock.fetch_add(1, atomic::Ordering::Relaxed);
       if SystemTime::now().duration_since(self.last_rotation).unwrap().as_secs_f64() > self.backup_interval {
           let snapshot = serde_json::to_string(&*self.state_cache.read().await).unwrap();
           let mut redis = self.redis.lock().await;
           redis.set(format!("elias:snapshot:{}", self.peer_id), &snapshot).await?;
           let mut hasher = Sha256::new();
           hasher.input(snapshot.as_bytes());
           redis.set(format!("elias:meta-snapshot:{}", self.peer_id), hasher.result_str()).await?;
           self.last_rotation = SystemTime::now();
       }
       let state_data = encrypted.as_bytes();
       if self.active_nodes.load(atomic::Ordering::Relaxed) < 1000 {
           self.max_states = 100;
           let mut redis = self.redis.lock().await;
           redis.set(&cid, &encrypted).await?;
       } else {
           let mut redis = self.redis.lock().await;
           if let Ok(config) = redis.get::<_, String>(&self.config_key).await {
               let config: HashMap<String, String> = serde_json::from_str(&config)?;
               if config.get("storagePriority") == Some(&"redis".to_string()) {
                   redis.set(&cid, &encrypted).await?;
               }
           } else {
